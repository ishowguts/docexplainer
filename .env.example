# Gemini API key — get free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL — additional Gemini keys for automatic rotation on quota exhaustion.
# The pipeline cycles through GEMINI_API_KEY, then _2, _3, _4, _5 in order.
# Use keys from different Google accounts to multiply your free-tier budget.
# Leave any slot blank to skip it.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# Bhashini API (optional — fallback to Gemini translation if not set)
# Register free at https://bhashini.gov.in/ulca/user/register
BHASHINI_API_KEY=
BHASHINI_USER_ID=
